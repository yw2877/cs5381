# .Rprofile - Auto-loads when R starts in this directory
# Sets default CRAN mirror to avoid "trying to use CRAN without setting a mirror" error

# Set CRAN mirror to Posit Package Manager (recommended)
options(repos = c(CRAN = "https://packagemanager.posit.co/cran/latest"))

# Alternative mirrors (uncomment if the above doesn't work):
# options(repos = "https://cran.rstudio.com/")
# options(repos = "https://mirrors.tuna.tsinghua.edu.cn/CRAN/")  # For users in China

cat("✅ CRAN mirror set to:", getOption("repos")["CRAN"], "\n")




